# ============= 应用 =============
APP_ENV=development
APP_PORT=8090
APP_VERSION=1.0.0

# ============= 数据库 =============
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=commute
DB_SSLMODE=disable

# ============= 高德（后端 Web Service） =============
AMAP_WS_KEY=
AMAP_WS_BASE=https://restapi.amap.com
AMAP_TIMEOUT_MS=10000

# ============= 高德（前端 JS SDK，前端 .env 使用） =============
VITE_AMAP_JS_KEY=
VITE_AMAP_JS_SECURITY=

# ============= 豆包（火山方舟） =============
DOUBAO_API_KEY=
DOUBAO_BASE=https://ark.cn-beijing.volces.com
DOUBAO_MODEL=
DOUBAO_TIMEOUT_MS=60000
